generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  password     String
  role         Role          @default(COLABORADOR)
  accessLevel  AccessLevel   @default(COLABORADOR) @map("access_level")
  colaborador  Colaborador?
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  @@map("users")
}

model Colaborador {
  id          Int                 @id @default(autoincrement())
  userId      Int                 @unique @map("user_id")
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  nome        String
  cpf         String              @unique
  nascimento  DateTime?
  telefone    String
  bloco       String
  unidade     String
  status      StatusColaborador   @default(PENDENTE)
  veiculos    Veiculo[]
  ocorrencias Ocorrencia[]
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  @@map("colaboradores")
}

model Veiculo {
  id             Int          @id @default(autoincrement())
  colaboradorId  Int          @map("colaborador_id")
  colaborador    Colaborador  @relation(fields: [colaboradorId], references: [id], onDelete: Cascade)
  placa          String       @unique
  tipo           TipoVeiculo
  createdAt      DateTime     @default(now()) @map("created_at")

  @@map("veiculos")
}

enum Role {
  ADMIN
  COLABORADOR
}

enum AccessLevel {
  ROOT
  ADMIN
  COLABORADOR
}

enum StatusColaborador {
  ATIVO
  PENDENTE
  BLOQUEADO
}

enum TipoVeiculo {
  CARRO
  MOTO
}

model Ocorrencia {
  id             Int           @id @default(autoincrement())
  colaboradorId  Int?          @map("colaborador_id")
  colaborador    Colaborador?  @relation(fields: [colaboradorId], references: [id], onDelete: SetNull)
  tipo           String
  local          String
  descricao      String
  prioridade     String        @default("MEDIA")
  status         String        @default("EM_ANALISE")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  @@index([colaboradorId])
  @@map("ocorrencias")
}
